APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

LLM_PROVIDER=auto
# auto: prefer LLMAPI when LLMAPI_API_KEY is set, otherwise OpenRouter
# llmapi|openrouter: force a provider

LLMAPI_BASE_URL=https://internal.llmapi.ai/v1
LLMAPI_CHAT_PATH=/chat/completions
LLMAPI_API_KEY=
# models (examples):
# openai/gpt-4.1-nano
# openai/gpt-4.1-mini
# openai/gpt-5.2
# openai/gpt-5-mini
LLMAPI_MODEL=
LLMAPI_PROVIDER_NAME=LLMAPI
LLMAPI_SOURCE=zstudy/mozart
# Reasoning effort (optional)
# Default allowed: none|low|medium|high|xhigh (aliases: minimal|min|minimum->low, max|very_high->xhigh)
# Some model families only accept low|medium|high (we clamp xhigh->high)
LLMAPI_REASONING_EFFORT=
# Optional per-model override:
# - GPT models (openai/gpt-*, gpt-*), examples:
#   - openai/gpt-5.2, openai/gpt-5-mini, openai/gpt-5-nano
#   - openai/gpt-4.1-mini, openai/gpt-4.1-nano
#   Use: low|medium|high (if you write "minimal", we'll treat it as low)
LLMAPI_REASONING_EFFORT_GPT=
# - Other models (non-GPT): can use none|low|medium|high|xhigh (or aliases like max/very_high)
LLMAPI_REASONING_EFFORT_OTHER=
LLMAPI_TEMPERATURE=0.7
LLMAPI_MAX_TOKENS=
LLMAPI_TOP_P=
LLMAPI_FREQUENCY_PENALTY=
# Examples:
# - json_object
# - {"type":"json_object"}
LLMAPI_RESPONSE_FORMAT=

OPENROUTER_BASE_URL=https://openrouter.ai
OPENROUTER_CHAT_PATH=/api/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_PROVIDER_NAME=OpenRouter
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=
OPENROUTER_TOP_P=
OPENROUTER_FREQUENCY_PENALTY=
OPENROUTER_RESPONSE_FORMAT=

VITE_APP_NAME="${APP_NAME}"
